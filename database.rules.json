{
  "rules": {
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['online', 'lastSeen'])",
        "online": {
          ".validate": "newData.isBoolean()"
        },
        "lastSeen": {
          ".validate": "newData.isNumber() || newData.val() === 'SERVER_TIMESTAMP'"
        },
        "username": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
